# App
APP_ENV=local
APP_NAME=ecommerce_agent_api
APP_PORT=8000
LOG_LEVEL=INFO

# Security
API_KEY=replace_with_dev_api_key

# Database
POSTGRES_URI=postgresql+psycopg2://postgres:postgres@localhost:5432/agentdb

# Cache / Session / Rate Limiting
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ACTIONS_TOPIC=tool_actions
KAFKA_TOOL_ACTIONS_DLQ_TOPIC=tool_actions_dlq

# LLM / Embeddings
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone
PINECONE_API_KEY=replace_with_pinecone_key
PINECONE_INDEX=ecommerce-faq
PINECONE_NAMESPACE=default

# Observability
ARIZE_API_KEY=replace_with_arize_key
ARIZE_SPACE_KEY=replace_with_arize_space_key
PHOENIX_PROJECT_NAME=ecommerce-agent-local
